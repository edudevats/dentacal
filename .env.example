# ── Entorno ─────────────────────────────────────────────────────────────────
FLASK_ENV=development           # development | production | testing

# ── Seguridad ────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-aleatoria-de-32-chars

# ── Base de Datos ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///consultorio.db
# Para PostgreSQL: postgresql://user:pass@localhost/dental_db

# ── Admin inicial (para manage.py crear_admin) ────────────────────────────────
ADMIN_EMAIL=admin@consultorio.com
ADMIN_PASSWORD=CambiameAhora1!

# ── Twilio WhatsApp ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+1xxxxxxxxxx

# ── Anthropic (bot IA) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Consultorio ──────────────────────────────────────────────────────────────
CONSULTORIO_NOMBRE=La Casa del Sr. Pérez
CONSULTORIO_DIRECCION=
CONSULTORIO_TELEFONO=
CLABE_INTERBANCARIA=000000000000000000
GOOGLE_MAPS_REVIEW_URL=https://g.page/r/xxxxxxxxxxxx/review

# ── Flask-Mail (email) ────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_gmail
MAIL_DEFAULT_SENDER=La Casa del Sr. Pérez <noreply@consultorio.com>
# Gmail: activa "Contraseñas de aplicación" en tu cuenta Google

# ── Flask-Caching ─────────────────────────────────────────────────────────────
# En producción con Redis (opcional):
# CACHE_TYPE=RedisCache
# REDIS_URL=redis://localhost:6379/0
# Por defecto usa SimpleCache (memoria, sin dependencias externas)

# ── JWT (tokens API) ──────────────────────────────────────────────────────────
JWT_EXPIRATION_SECONDS=3600    # 1 hora
